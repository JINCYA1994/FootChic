<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FootChic Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <style>
    body{
      background:#f6f7fb;
      font-family: Arial, sans-serif;
    }

    /* Sidebar */
    .sidebar{
      width:250px;
      height:100vh;
      background:#f0f2f0;
      position:fixed;
      top:0;
      left:0;
      padding:20px;
      border-right:1px solid #ddd;
    }

    .sidebar h4{
      font-weight:700;
      color:#2d7f3a;
      margin-bottom:30px;
    }

    .sidebar a{
      display:block;
      padding:12px 15px;
      border-radius:8px;
      text-decoration:none;
      color:#333;
      font-weight:600;
      margin-bottom:10px;
      transition:0.3s;
    }

    .sidebar a:hover{
      background:#d9f5dd;
      color:#2d7f3a;
    }

    .sidebar a.active{
      background:#2d7f3a;
      color:white;
    }

    /* Main Content */
    .main-content{
      margin-left:250px;
      padding:20px;
    }

    /* Top Navbar */
    .topbar{
      background:white;
      border-radius:12px;
      padding:12px 20px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      box-shadow:0px 2px 8px rgba(0,0,0,0.05);
    }

    .search-box{
      width:350px;
      background:#f6f7fb;
      border-radius:25px;
      padding:8px 15px;
      display:flex;
      align-items:center;
      gap:10px;
    }

    .search-box input{
      border:none;
      outline:none;
      background:transparent;
      width:100%;
    }

    /* Cards */
    .stat-card{
      background:white;
      border-radius:12px;
      padding:20px;
      box-shadow:0px 2px 10px rgba(0,0,0,0.06);
      border:1px solid #eee;
    }

    .stat-card h6{
      color:gray;
      font-size:14px;
      margin-bottom:10px;
    }

    .stat-card h3{
      font-weight:700;
      margin-bottom:5px;
    }

    .stat-card small{
      color:green;
      font-weight:600;
    }

    /* Section Card */
    .box-card{
      background:white;
      border-radius:12px;
      padding:20px;
      box-shadow:0px 2px 10px rgba(0,0,0,0.06);
      border:1px solid #eee;
    }
  </style>
</head>

<body>

<div class="sidebar">
  <h4>FootChic</h4>

  <a href="/admin/dashboard" class="active"><i class="fa-solid fa-chart-line me-2"></i>Dashboard</a>
 
  <a href="/admin/users"><i class="fa-solid fa-users me-2"></i>Customers</a>
 
  <a href="/admin/category"><i class="fa-solid fa-layer-group me-2"></i>Categories</a>
  <a href="/admin/products"><i class="fa-solid fa-box me-2"></i>Products</a>
   <a href="/admin/coupons"><i class=" fa-solid fa-ticket me-2"></i>Coupons</a>
   <a href="/admin/offers"><i class="fa-solid fa-tags me-2"></i>Offers</a>
  <a href="/admin/orders"> <i class="fa-solid fa-bag-shopping me-2"></i>Orders</a>
  <a href="/admin/salesreport"> <i class="fa-solid fa-bag-shopping me-2"></i>Sales report</a>
  <a href="/admin/logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Logout</a>
</div>

<div class="main-content">
