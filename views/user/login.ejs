<%-include("../../views/partials/user/header")%>


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login | FootChic</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- CSS Links -->
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-papX2UML7TRO7kDk4UfBkx9Uj7DvuP+nayKYBy7KIlEw6cUwzbf7tMoD7g8bkBl9mrUPex8Z/YrbRu6f8j8Ig==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

<style>
body{
  background:#f6f2ea;
  font-family: "Segoe UI", sans-serif;
}

.login-wrapper{
  min-height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
}

.login-card{
  width:900px;
  height:520px;
  display:flex;
  border-radius:25px;
  overflow:hidden;
  background:#fff;
}

/* LEFT SIDE */
.login-left{
  width:45%;
  background:linear-gradient(135deg,#111,#444);
  color:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  text-align:center;
}

.brand h2{

  font-size:34px;
  margin-top:15px;
  color:#fff;
}

.brand p{
  font-size:14px;
  opacity:0.8;
  color:#fff;
}

.brand h3{
  margin-top:25px;
  font-size:26px;
  color:#fff;
}

.logo-circle{
  width:90px;
  height:90px;
  background:white;
  border-radius:50%;
  display:flex;
  justify-content:center;
  align-items:center;
  margin:0 auto 12px;
}

.logo-circle img{
  width:55px;
  height:55px;
  object-fit:contain;
}

/* RIGHT SIDE */
.login-right{
  width:55%;
  padding:60px;
}

.login-right h2{
  font-size:30px;
  margin-bottom:30px;
}

.input-group-ui{
  display:flex;
  align-items:center;
  border:1px solid #e0d8cc;
  border-radius:12px;
  padding:12px;
  margin-bottom:20px;
}

.input-group-ui i{
  color:#888;
  margin-right:10px;
}

.input-group-ui input{
  border:none;
  outline:none;
  width:100%;
  font-size:15px;
}

.forgot{
  display:block;
  text-align:right;
  font-size:14px;
  color:#2a66ff;
  margin-bottom:25px;
  text-decoration:none;
}

.btn-login-ui{
  width:100%;
  background:#c99a5b;
  border:none;
  padding:14px 0;
  border-radius:30px;
  color:#fff;
  font-size:16px;
  font-weight:600;
  cursor:pointer;
  margin-top:10px;
}
.input-wrapper{
    margin-bottom:18px;
}

.error-text{
    display:block;
    color:#dc3545;
    font-size:14px;
    margin-top:4px;
    margin-left:12px;
}
/* Google button – match login button */
.google-btn{
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  border:1px solid #e0d8cc;
  border-radius:30px;
  padding:12px 0;
  font-weight:600;
  color:#555;
  background:#fff;
  margin-top:18px;
  transition: box-shadow 0.3s;
}

.google-btn img{
  width:22px;
  height:22px;
}

.google-btn:hover{
  box-shadow:0 6px 15px rgba(0,0,0,0.15);
}

.signup-text{
  margin-top:25px;
  font-size:14px;
}

.signup-text a{
  color:#2a66ff;
  text-decoration:none;
}
</style>

</head>
<body>

 <div class="login-wrapper">
  <div class="login-card">

    <!-- LEFT PANEL -->
    <div class="login-left">
      <div class="brand">
      <div class="logo-circle">
       <img src="/img/footchiclogo.png" alt="Footchic Logo">
       </div>
        <h2>Footchic</h2>
        <p>Your Style Starts Here</p>
        <h3>Welcome Back..!</h3>
      </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="login-right">
      <h2>Login</h2>

      <form id="loginForm">
        <input type="hidden" id="message" value="<%= message %>" name="message"/>

      
<div class="input-wrapper">
    <div class="input-group-ui">
        <i class="fa-solid fa-envelope"></i>
        <input
            type="text"
            id="email"
            name="email"
            placeholder="Enter your email">
    </div>

    <small id="emailError" class="error-text"></small>
</div>
<div class="input-wrapper">
    <div class="input-group-ui">
        <i class="fa-solid fa-lock"></i>

        <input
            type="password"
            id="password"
            name="password"
            placeholder="Enter your password">

        <i
            class="fa-solid fa-eye"
            id="togglePassword"
            style="cursor:pointer;"></i>
    </div>

    <small id="passwordError" class="error-text"></small>
</div>
        <a href="/forgot-password" class="forgot">Forgot your password?</a>

        <button type="submit" class="btn-login-ui">Login</button>
      </form>

   
           <a href="/auth/google" class="google-btn">
        <img src="https://img.icons8.com/color/48/000000/google-logo.png">
        <span> Login with Google</span>
      </a>

      <p class="signup-text">
        Don't have an account? <a href="/signup">Sign up</a>
      </p>
    </div>

  </div>
</div>


</body>
<script>
document.addEventListener('DOMContentLoaded',function(){
  const message = document.getElementById('message').value; 
    if (message) {
         swal(message); 
         }
  document.getElementById('loginForm').addEventListener('submit', formvalidate); });

async function formvalidate(e) {
  
         e.preventDefault()
var email =document.getElementById('email').value; 
var password =document.getElementById('password').value.trim(); 
document.getElementById("emailError").innerHTML = "";
document.getElementById("passwordError").innerHTML = "";

let valid = true;

if(email.trim() === ""){

    document.getElementById("emailError").innerHTML ="Email is required";
    valid = false;
}

if(password.trim() === ""){

    document.getElementById("passwordError").innerHTML =
    "Password is required";

    valid = false;
}

if(!valid){
    return;
}
const emailformat=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;

if(!emailformat.test(email)){

    document.getElementById("emailError").innerHTML =
    "Please enter a valid email";

    return;
}


if(password.length < 6){

    document.getElementById("passwordError").innerHTML =
    "Password must be at least 6 characters";

    return;
}
    
try{

const response = await fetch("/login",{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({email,password})
})

const data = await response.json()

// if(data.success){


if(data.success){

    window.location.href="/home";

}else{

    if(data.field==="email"){

        document.getElementById("emailError").innerHTML =
        data.message;

    }

    if(data.field==="password"){

        document.getElementById("passwordError").innerHTML =
        data.message;

    }

    if(!data.field){

        swal(data.message);

    }

}
}catch(error){

swal("Something went wrong")

}
}
  
const togglePassword = document.getElementById("togglePassword");
const password = document.getElementById("password");

togglePassword.addEventListener("click", function () {

  const type = password.getAttribute("type") === "password" ? "text" : "password";
  password.setAttribute("type", type);

  this.classList.toggle("fa-eye");
  this.classList.toggle("fa-eye-slash");

});







</script>


<%-include("../../views/partials/user/footer")%>