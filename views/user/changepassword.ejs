<%- include("../../views/partials/user/header") %>

<div class="container mt-5">
 <% if (success_msg && success_msg.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <%= success_msg[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (error_msg && error_msg.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error_msg[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>


<div class="container mt-5 mb-5">
  <div class="card mx-auto shadow p-4" style="max-width: 450px; border-radius:10px;">
    
    <h3 class="text-center mb-4">Change Password</h3>

    <form action="/change-password?_method=PATCH" method="POST">

      <!-- Current Password -->
      <div class="mb-3 position-relative">
        <label class="form-label">Current Password</label>
        <input type="password" id="currentPassword" name="currentPassword" class="form-control">

        <i class="fa-solid fa-eye position-absolute"
           id="toggleCurrent"
           style="right:15px; top:38px; cursor:pointer;"></i>
      </div>

      <!-- New Password -->
      <div class="mb-3 position-relative">
        <label class="form-label">New Password</label>
        <input type="password" id="newPassword" name="newPassword" class="form-control">

        <i class="fa-solid fa-eye position-absolute"
           id="toggleNew"
           style="right:15px; top:38px; cursor:pointer;"></i>
      </div>

      <!-- Confirm Password -->
      <div class="mb-3 position-relative">
        <label class="form-label">Confirm New Password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control">

        <i class="fa-solid fa-eye position-absolute"
           id="toggleConfirm"
           style="right:15px; top:38px; cursor:pointer;"></i>
      </div>

      <button type="submit" class="btn btn-dark w-100">
        Change Password
      </button>

    </form>
  </div>
</div>

<!-- Font Awesome (IMPORTANT) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<script>
document.addEventListener("DOMContentLoaded", function () {

  function toggle(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);

    icon.addEventListener("click", function () {
      const type = input.type === "password" ? "text" : "password";
      input.type = type;

      this.classList.toggle("fa-eye");
      this.classList.toggle("fa-eye-slash");
    });
  }

  toggle("currentPassword", "toggleCurrent");
  toggle("newPassword", "toggleNew");
  toggle("confirmPassword", "toggleConfirm");

});
</script>


<%- include("../../views/partials/user/footer") %>
