<script src="https://checkout.razorpay.com/v1/checkout.js"></script>


<script>
document.getElementById("orderForm").addEventListener("submit", async function(e) {
  e.preventDefault();

  const selectedAddress = document.getElementById("selectedAddressInput").value;

  if (!selectedAddress) {
      Swal.fire("Select an address");
    return;
  }

  const paymentMethod = document.querySelector("input[name='paymentMethod']:checked").value;

// COD
if (paymentMethod === "COD") {

  window.location.href =
    "/place-order-cod?addressId=" + selectedAddress;

  return;
}

// WALLET
if (paymentMethod === "Wallet") {

  window.location.href =
    "/place-order-wallet?addressId=" + selectedAddress;

  return;
}

// ONLINE PAYMENT
const res = await fetch("/place-order", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ selectedAddress })
  });

  const data = await res.json();

  if (data.success) {
   
const options = {

  key: "<%= process.env.RAZORPAY_KEY_ID %>",
  amount: data.razorpayOrder.amount,
  currency: "INR",
  order_id: data.razorpayOrder.id,

  handler: async function (response) {

    const verifyRes = await fetch("/verify-payment", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        ...response,
        addressId: selectedAddress,
         orderId: data.orderId
      })
    });

    const verifyData = await verifyRes.json();

    if (verifyData.success) {

      window.location.href =
        "/order-success/" + verifyData.orderId;

    } else {

      window.location.href =
        "/order-failure?error=verification_failed";

    }
  },

  modal: {

    ondismiss: async function () {
   await fetch("/update-payment-failed", {

      method: "POST",

      headers: {
        "Content-Type": "application/json"
      },

      body: JSON.stringify({
        orderId: data.orderId
      })

    });   

window.location.href =
  "/order-failure?error=payment_cancelled&orderId=" + data.orderId;

    }
  }

};
    const rzp = new Razorpay(options);


rzp.on("payment.failed", async function(response) {
 await fetch("/update-payment-failed", {

    method: "POST",

    headers: {
      "Content-Type": "application/json"
    },

    body: JSON.stringify({
      orderId: data.orderId
    })

  });
 window.location.href =
  "/order-failure?error=" +
  encodeURIComponent(response.error.description) +
  "&orderId=" + data.orderId;
  
});
    rzp.open();
  }
});
</script>


