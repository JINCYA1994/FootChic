<%- include("../partials/user/header") %>

<div class="container py-5">
  <div class="row">

    <!-- LEFT SIDE - ADDRESS SECTION -->
    <div class="col-md-7 mb-4">

      <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="fw-bold">Shipping Address</h5>
        <button class="btn btn-sm btn-dark" id="addAddressBtn">
ADD NEW ADDRESS
</button>
        </div>

        <% addresses.forEach(address => { %>

          <div class="border rounded p-3 mb-3">

            <div class="form-check">
              <input class="form-check-input"
                     type="radio"
                     name="selectedAddress"
                     value="<%= address._id %>"
                     <%= address.is_default ? "checked" : "" %> >
            </div>

            <h6 class="fw-bold mt-2">
              <%= address.name %>
            </h6>

            <p class="mb-1">
              <%= address.house_name %>, <%= address.locality%>
            </p>

            <p class="mb-1">
              <%= address.city %>, <%= address.state %>
            </p>

            <p class="mb-1">
              Pin: <%= address.pincode %>
            </p>

            <p>
              Ph: <%= address.mobilenumber %>
            </p>

          <button class="btn btn-sm btn-dark editAddressBtn"
data-id="<%= address._id %>"
data-name="<%= address.name %>"
data-house="<%= address.house_name %>"
data-locality="<%= address.locality %>"
data-city="<%= address.city %>"
data-state="<%= address.state %>"
data-pincode="<%= address.pincode %>"
data-mobile="<%= address.mobilenumber %>">

Edit
</button>

          </div>

        <% }) %>

      </div>

    </div>


    <!-- RIGHT SIDE - ORDER SUMMARY -->
    <div class="col-md-5">

      <div class="card shadow-sm p-4">

        <h5 class="fw-bold mb-4">Your Order</h5>

        <!-- PRODUCT LIST -->
       <% cart.items.forEach(item => { 

  const variant = item.product_id.variants.find(v =>
    v._id.toString() === item.var_id.toString()
  );
const originalPrice = variant?.price || 0;
const sellingPrice = item.finalPrice || originalPrice;


  const image = variant?.images?.[0] || "/images/default.png";
%>

<div class="d-flex justify-content-between align-items-center mb-3">

  <div class="d-flex align-items-center">
    <img src="<%= image %>" width="60" class="me-3 rounded">

    <div>
      <h6 class="mb-1">
        <%= item.product_id.product_name %>
      </h6>
      <small>Size: <%= item.size %></small><br>
      <small>Qty: <%= item.quantity %></small>

<% if (sellingPrice < originalPrice) { %>

<div>
  <small class="text-muted text-decoration-line-through">
    ₹<%= originalPrice %>
  </small>

  <small class="text-danger fw-bold ms-2">
    ₹<%= sellingPrice %>
  </small>
</div>

<% } else { %>

<div>
  ₹<%= originalPrice %>
</div>

<% } %>

</div>
  </div>

  <strong>
    ₹<%= sellingPrice * item.quantity %>
  </strong>

</div>

<% }) %>

        <hr>



  <div class="input-group mb-2">
    <input type="text"  id="couponInput"
           class="form-control"
           placeholder="Enter coupon code"
           name="couponCode">
        
    <button class="btn btn-outline-dark"  id="applyCouponBtn">
      APPLY
    </button>

<!-- <button class="btn btn-sm btn-danger w-100 mt-2 d-none" id="removeCouponBtn">
  REMOVE COUPON
</button> -->

  </div>



<button class="btn btn-sm btn-warning w-100"
        data-bs-toggle="modal"
        data-bs-target="#couponModal">
  VIEW AVAILABLE COUPONS
</button>
</div>

        <hr>

        <!-- PRICE SUMMARY -->
        <div class="d-flex justify-content-between mb-2">
          <span>Subtotal</span>
          <span   id="subtotal">₹<%= subtotal %></span>
        </div>

        <div class="d-flex justify-content-between mb-2 text-success">
          <span>Coupon Discount</span>
          <span id="discount"  >- ₹<%= discount %></span>
        </div>
  <div class="d-flex justify-content-between mb-2 ">
          <span>Taxes</span>
          <span id="taxes"  >₹<%= taxes %></span>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span  id="shipping"   >Shipping</span>
          <span>₹<%= shipping %></span>
        </div>

        <hr>

        <div class="d-flex justify-content-between fw-bold fs-5">
          <span>Total</span>
          <span  id="finalAmount" >₹<%= finalAmount %></span>
        </div>

        <hr>

        <!-- PAYMENT METHODS -->
        <!-- <form action="/place-order" method="POST"> -->
          <form id="orderForm">
          <input type="hidden" name="redirectTo" value="/checkout">

          <input type="hidden" name="selectedAddress" id="selectedAddressInput">

          <h6 class="fw-bold mb-3">Payment Method</h6>

          <div class="form-check mb-2">
            <input class="form-check-input"
                   type="radio"
                   name="paymentMethod"
                   value="Online">
            <label class="form-check-label">
              Online Payment
            </label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input"
                   type="radio"
                   name="paymentMethod"
                   value="Wallet">
            <label class="form-check-label">
              Wallet Payment
            </label>
          </div>

          <div class="form-check mb-4">
            <input class="form-check-input"
                   type="radio"
                   name="paymentMethod"
                   value="COD"
                   checked>
            <label class="form-check-label">
              Cash on Delivery
            </label>
          </div>

          <button type="submit"
                  class="btn btn-warning w-100 fw-bold py-2">
            PLACE ORDER
          </button>

        </form>

      </div>

    </div>

  </div>
</div>
<!-- COUPON MODAL -->
<div class="modal fade" id="couponModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">

      <!-- HEADER -->
      <div class="modal-header">
        <h5 class="modal-title">Available Coupons</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <!-- BODY -->
      <div class="modal-body">
        <div class="row">

          <% coupons.forEach(coupon => { 

          
            let saveAmount = "";

            if (coupon.discount_type === "flat") {
              saveAmount = "₹" + coupon.discount_value;
            } else if (coupon.discount_type === "percentage") {
              saveAmount = coupon.discount_value + "%";

              if (coupon.max_discount) {
                saveAmount += " (Up to ₹" + coupon.max_discount + ")";
              }
            }

            const isEligible = subtotal >= coupon.min_purchase;

          %>

          <div class="col-md-6 mb-3">
            <div class="coupon-card p-3">

              <!-- TOP -->
              <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-muted">
                  Min Order: ₹<%= coupon.min_purchase %>
                </small>

                <span class="badge bg-success">
                  SAVE <%= saveAmount %>
                </span>
              </div>

              <!-- CODE -->
              <h5 class="fw-bold"><%= coupon.code %></h5>

              <!-- VALID DATE -->
              <small class="text-muted d-block mb-2">
                Valid till <%= new Date(coupon.end_date).toLocaleDateString() %>
              </small>

              <!-- BUTTON -->
              <% if (isEligible) { %>

                <button class="btn btn-outline-dark btn-sm copyBtn"
                        data-code="<%= coupon.code %>">
                  COPY
                </button>

              <% } else { %>

                <button class="btn btn-light btn-sm text-muted" disabled>
                  Add ₹<%= coupon.min_purchase - subtotal %> more
                </button>

              <% } %>

            </div>
          </div>

          <% }) %>

        </div>
      </div>

    </div>
  </div>
</div>
<script>

document.querySelectorAll(".copyBtn").forEach(btn => {

  btn.addEventListener("click", function () {

    navigator.clipboard.writeText(this.dataset.code);

    Swal.fire({
      icon: "success",
      title: "Copied!",
      text: "Coupon code copied successfully",
      timer: 1500,
      showConfirmButton: false
    });

  });

});

const applyBtn = document.getElementById("applyCouponBtn");

let couponApplied = false;

applyBtn.addEventListener("click", async () => {

  // REMOVE COUPON
  if (couponApplied) {

    const res = await fetch("/remove-coupon", {
      method: "POST"
    });

    const data = await res.json();

    document.getElementById("discount").innerText = "-₹0";
    document.getElementById("finalAmount").innerText = "₹" + data.finalAmount;

    applyBtn.innerText = "APPLY";
    applyBtn.classList.remove("btn-danger");
    applyBtn.classList.add("btn-outline-dark");

    document.getElementById("couponInput").value = "";

    couponApplied = false;

    Swal.fire({
      icon: "success",
      title: "Coupon Removed"
    });

    return;
  }

  // APPLY COUPON
  const code = document.getElementById("couponInput").value.trim();

  if (!code) {
    Swal.fire({
      icon: "warning",
      title: "Enter coupon code"
    });
    return;
  }

  const res = await fetch("/apply-coupon", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ code })
  });

  const data = await res.json();

  if (data.success) {

    document.getElementById("discount").innerText = "-₹" + data.discount;

    document.getElementById("finalAmount").innerText =
      "₹" + data.finalAmount;

    applyBtn.innerText = "REMOVE";

    applyBtn.classList.remove("btn-outline-dark");

    applyBtn.classList.add("btn-danger");

    couponApplied = true;

    Swal.fire({
      icon: "success",
      title: "Coupon Applied"
    });

  } else {

    Swal.fire({
      icon: "error",
      title: data.message
    });

  }

});

</script>

<script>
  // Automatically set selected address into hidden input
  const radios = document.querySelectorAll("input[name='selectedAddress']");
  const hiddenInput = document.getElementById("selectedAddressInput");

  radios.forEach(radio => {
    radio.addEventListener("change", function () {
      hiddenInput.value = this.value;
