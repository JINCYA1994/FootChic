<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

<style>
  body {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    font-family: 'Poppins', sans-serif;
  }

  /* OTP Container */
  .otp-container {
    max-width: 420px;
    margin: 90px auto;
    padding: 35px 30px;
    border-radius: 18px;
    background: #ffffff;
    text-align: center;
    border: 1px solid #f0f0f0;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    position: relative;
    overflow: hidden;
  }

  /* Top Gradient Border Effect */
  .otp-container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    height: 6px;
    width: 100%;
    background: linear-gradient(90deg, #28a745, #20c997, #17a2b8);
  }

  /* Heading */
  .otp-container h2 {
    margin-bottom: 25px;
    font-weight: 700;
    font-size: 26px;
    color: #222;
    letter-spacing: 0.5px;
  }

  /* OTP input boxes */
  .otp-inputs input {
    width: 52px;
    height: 55px;
    font-size: 22px;
    font-weight: 700;
    text-align: center;
    border-radius: 12px;
    border: 1px solid #ddd;
    margin: 0 6px;
    transition: 0.25s ease;
    background: #f8f9fa;
  }

  .otp-inputs input:focus {
    border-color: #28a745;
    box-shadow: 0 0 10px rgba(40, 167, 69, 0.25);
    outline: none;
    transform: scale(1.05);
    background: #fff;
  }

  /* Verify OTP button */
  .btn-verify {
    background: linear-gradient(90deg, #28a745, #20c997);
    color: white;
    font-weight: 700;
    border: none;
    border-radius: 12px;
    padding: 13px;
    font-size: 16px;
    transition: 0.3s;
    box-shadow: 0 8px 18px rgba(40, 167, 69, 0.25);
  }

  .btn-verify:hover {
    background: linear-gradient(90deg, #218838, #17a589);
    transform: translateY(-2px);
  }

  /* Timer */
  #timer {
    font-size: 14px;
    color: #555;
    font-weight: 500;
  }

  /* Resend OTP link */
  #resendLink {
    font-size: 14px;
    color: #007bff;
    opacity: 0.6;
    pointer-events: none;
    transition: 0.3s;
  }

  #resendLink.active {
    opacity: 1;
    pointer-events: auto;
    font-weight: 700;
    color: #007bff;
  }

  #resendLink.active:hover {
    text-decoration: underline;
  }
</style>


<div class="otp-container">
  <h2>OTP Verification</h2>

  <form action="/forgot-verify-otp" method="POST">
    <input type="hidden" id="message" value="<%= typeof message !== 'undefined' ? message : '' %>"/>
    <input type="hidden" name="email" id="email"     value="<%= email %>"/>
    <input type="hidden" name="purpose" id="purpose"    value="<%= purpose %>"/>

    <div class="otp-inputs d-flex justify-content-center mb-3">
      <input type="text" maxlength="1" name="otp[]" required>
      <input type="text" maxlength="1" name="otp[]" required>
      <input type="text" maxlength="1" name="otp[]" required>
      <input type="text" maxlength="1" name="otp[]" required>
      <input type="text" maxlength="1" name="otp[]" required>
      <input type="text" maxlength="1" name="otp[]" required>
    </div>

    <button type="submit" class="btn btn-verify w-100">Verify OTP</button>
  </form>

  <div class="timer mt-2 mb-2" id="timer"></div>
  <a href="#" id="resendLink" class="d-block text-center">Resend OTP</a>
</div>


