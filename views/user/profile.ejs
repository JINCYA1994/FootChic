<%- include('../../views/partials/user/header') %>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Profile | FootChic</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/profile.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
  background-color:#f5f5f5;
  font-family:'Poppins',sans-serif;
}

.breadcrumb{
  background-color:transparent;
  font-size:15px;
  margin-top:50px;
  margin-left:80px;
}

.card-custom{
  background-color:#fff;
  border-radius:15px;
  padding:25px 30px;
  box-shadow:0 3px 8px rgba(0,0,0,0.08);
  border:1px solid #ddd;
}

.badge{
  font-size:12px;
  padding:5px 10px;
  border-radius:20px;
}

.card-custom h5{
  font-weight:700;
  border-bottom:2px solid #000;
  padding-bottom:10px;
  margin-bottom:20px;
}

.address-box{
  border:1px solid #000;
  background:#fff;
  border-radius:10px;
  padding:15px 20px;
  margin-top:15px;
}

.btn-edit{
  background:#000;
  color:#fff;
  border:none;
  border-radius:8px;
  padding:8px 20px;
  font-weight:600;
}

.btn-edit:hover{
  background:#333;
}

</style>
</head>

<body>

<nav aria-label="breadcrumb">
<ol class="breadcrumb">
<li class="breadcrumb-item"><a href="/" class="text-decoration-none text-dark">Home</a></li>
<li class="breadcrumb-item active">Profile</li>
</ol>
</nav>

<div class="profile-container">

<%- include('../../views/partials/user/profileSidebar',{
userData:userData,
activePage:'profile'
}) %>

<div class="profile-content">

<div class="card-custom">

<div class="d-flex justify-content-between align-items-center mb-3">
<h5 class="mb-0">Personal Information</h5>

<button class="btn-edit" onclick="window.location.href='/edit-profile'">
Edit Profile
</button>
</div>

<p><strong>Name:</strong> <%= userData.username %></p>
<p><strong>Email:</strong> <%= userData.email %></p>
<p><strong>Referral Code:</strong> <%= userData. referralCode%></p>


<!-- Default Address -->
<% if(defaultAddress){ %>

<div class="address-box">

<h6 class="fw-bold mb-2">
Address
<span class="badge bg-dark ms-2">Default</span>
</h6>

<p><strong><%= defaultAddress.name %></strong></p>
<p><%= defaultAddress.house_name %>, <%= defaultAddress.locality %></p>
<p><%= defaultAddress.city %>, <%= defaultAddress.state %> - <%= defaultAddress.pincode %></p>
<p><%= defaultAddress.mobilenumber %></p>

</div>

<% } else { %>

<div class="alert alert-dark mt-3">
No address found.
</div>

<% } %>

</div>

</div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<% if (profileMessage) { %>
<script>
  Swal.fire({
    icon: 'success',
   
    text: '<%= profileMessage %>',
    confirmButtonColor: '#28a745',
    confirmButtonText: 'OK'
  });
</script>
<% } %>
</body>
</html>

<%- include('../../views/partials/user/footer') %>