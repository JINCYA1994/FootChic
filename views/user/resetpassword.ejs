<%-include("../../views/partials/user/header")%>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Reset Password | FootChic</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- CSS Links -->
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

  <style>
    body{
      background:#f6f2ea;
      font-family: "Segoe UI", sans-serif;
    }

    .login-wrapper{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
    }

    .login-card{
      width:900px;
      height:520px;
      display:flex;
      border-radius:25px;
      overflow:hidden;
      background:#fff;
    }

    /* LEFT SIDE */
    .login-left{
      width:45%;
      background:linear-gradient(135deg,#111,#444);
      color:#fff;
      display:flex;
      justify-content:center;
      align-items:center;
      text-align:center;
    }

    .brand h2{
      font-size:34px;
      margin-top:15px;
      color:#fff;
    }

    .brand p{
      font-size:14px;
      opacity:0.8;
      color:#fff;
    }

    .brand h3{
      margin-top:25px;
      font-size:26px;
      color:#fff;
    }

    /* SAME LOGO STYLE AS FORGOT PASSWORD */
    .logo-circle{
      width:90px;
      height:90px;
      background:white;
      border-radius:50%;
      display:flex;
      justify-content:center;
      align-items:center;
      margin:0 auto 12px;
    }

    .logo-circle img{
      width:55px;
      height:55px;
      object-fit:contain;
    }

    /* RIGHT SIDE */
    .login-right{
      width:55%;
      padding:60px;
    }

    .login-right h2{
      font-size:30px;
      margin-bottom:15px;
    }

    .login-right p{
      font-size:14px;
      color:#666;
      margin-bottom:25px;
    }

    .input-group-ui{
      display:flex;
      align-items:center;
      border:1px solid #e0d8cc;
      border-radius:12px;
      padding:12px;
      margin-bottom:12px;
    }

    .input-group-ui i{
      color:#888;
      margin-right:10px;
    }

    .input-group-ui input{
      border:none;
      outline:none;
      width:100%;
      font-size:15px;
      background:transparent;
    }

    .btn-login-ui{
      width:100%;
      background:#c99a5b;
      border:none;
      padding:14px 0;
      border-radius:30px;
      color:#fff;
      font-size:16px;
      font-weight:600;
      cursor:pointer;
      margin-top:15px;
    }

    .btn-login-ui:hover{
      background:#b8894d;
    }

    .signup-link{
      margin-top:18px;
      display:block;
      font-size:14px;
      text-align:center;
      color:#2a66ff;
      text-decoration:none;
    }

    .signup-link:hover{
      text-decoration:underline;
    }
  </style>
</head>

<body>
<% if (success && success.length > 0) { %>
  <script>
    swal("Success!", "<%= success[0] %>", "success");
  </script>
<% } %>

<% if (error && error.length > 0) { %>
  <script>
    swal("Error!", "<%= error[0] %>", "error");
  </script>
<% } %>

<div class="login-wrapper">
  <div class="login-card">

    <!-- LEFT PANEL -->
    <div class="login-left">
      <div class="brand">
        <div class="logo-circle">
          <img src="/img/footchiclogo.png" alt="Footchic Logo">
        </div>
        <h2>Footchic</h2>
        <p>Your Style Starts Here</p>
        <h3>Secure Access</h3>
      </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="login-right">
      <h2>Reset Password</h2>
      <p>Create a new secure password for your account.</p>

      <form id="resetForm" action="/reset-password" method="POST">
       
        <input type="hidden" name="email" value="<%= email %>">

        <!-- <div class="input-group-ui">
          <i class="fa-solid fa-lock"></i>
          <input type="password" id="password" name="password" placeholder="Enter new password">
        </div> -->

        <div class="input-group-ui">
  <i class="fa-solid fa-lock"></i>
  <input type="password" id="password" name="password" placeholder="Enter new Password">
  <i class="fa-solid fa-eye" id="togglePassword1" style="cursor:pointer;"></i>
</div>  

<!-- 
        <div class="input-group-ui">
          <i class="fa-solid fa-lock"></i>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter new password">
        </div> -->


        
        <div class="input-group-ui">
  <i class="fa-solid fa-lock"></i>
  <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter new password">
  <i class="fa-solid fa-eye" id="togglePassword2" style="cursor:pointer;"></i>
</div>  
        <button type="submit" class="btn-login-ui">
          <i class="fa-solid fa-key me-2"></i> Change Password
        </button>
      </form>

      <a href="/login" class="signup-link">
        <i class="fa-solid fa-arrow-left me-1"></i> Back to Login
      </a>
    </div>

  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function(){
  
  document.getElementById('resetForm').addEventListener('submit', validateForm);
});

function validateForm(e){
  const password = document.getElementById('password').value.trim();
  const confirm = document.getElementById('confirmPassword').value.trim();

  if(!password || !confirm){
    swal("All fields are required");
    e.preventDefault();
    return false;
  }

  if(password.length < 6){
    swal("Password must be at least 6 characters");
    e.preventDefault();
    return false;
  }

  if(password !== confirm){
    swal("Passwords do not match");
    e.preventDefault();
    return false;
  }

  return true;
}

 
const togglePassword1 = document.getElementById("togglePassword1");
const password = document.getElementById("password");

const togglePassword2 = document.getElementById("togglePassword2");
const confirmPassword = document.getElementById("confirmPassword");

// Password toggle
togglePassword1.addEventListener("click", function () {
  const type = password.type === "password" ? "text" : "password";
  password.type = type;

  this.classList.toggle("fa-eye");
  this.classList.toggle("fa-eye-slash");
});

// Confirm password toggle
togglePassword2.addEventListener("click", function () {
  const type = confirmPassword.type === "password" ? "text" : "password";
  confirmPassword.type = type;

  this.classList.toggle("fa-eye");
  this.classList.toggle("fa-eye-slash");
});


</script>
</body>



</html>

<%-include("../../views/partials/user/footer")%>
