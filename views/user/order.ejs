<script>
function retryPayment(orderId) {

  // ORDER ID CHECK
  if (!orderId) {

    alert("Invalid order");

    window.location.href = "/orders";

    return;

  }

  // CREATE NEW RAZORPAY ORDER
  fetch("/payment/razorpay/create-order", {

    method: "POST",

    headers: {
      "Content-Type": "application/json"
    },

    body: JSON.stringify({
      orderId
    })

  })

  .then(res => res.json())

  .then(data => {

    // CREATE ORDER FAILED
    if (!data.success) {

      alert("Unable to retry payment");

      return;

    }

    // RAZORPAY OPTIONS
    const options = {

      key: data.keyId,

      amount: data.amount,

      currency: "INR",

      order_id: data.razorpayOrderId,

      name: "Your Store",

      description: "Retry Payment",

      // PAYMENT SUCCESS
      handler: function (response) {

        fetch("/verify-payment", {

          method: "POST",

          headers: {
            "Content-Type": "application/json"
          },

          body: JSON.stringify({

            razorpay_order_id:
              response.razorpay_order_id,

            razorpay_payment_id:
              response.razorpay_payment_id,

            razorpay_signature:
              response.razorpay_signature,

            orderId: orderId

          })

        })

        .then(res => res.json())

        .then(result => {

          // PAYMENT VERIFIED
          if (result.success) {

            window.location.href =
              "/order-success/" + orderId;

          }

          // VERIFICATION FAILED
          else {

            window.location.href =
              "/order-failure?orderId=" + orderId;

          }

        });

      },

      // POPUP CLOSED
      modal: {

        ondismiss: function () {

          window.location.href =
            "/order-failure?orderId=" + orderId;

        }

      }

    };

    // OPEN RAZORPAY
    const rzp = new Razorpay(options);

    // PAYMENT FAILED EVENT
    rzp.on("payment.failed", function (response) {

      window.location.href =
        "/order-failure?error=" +
        encodeURIComponent(response.error.description) +
        "&orderId=" + orderId;

    });

    rzp.open();

  });

}
</script>



<% if (orderMessage) { %>
<script>
  Swal.fire({
    icon: 'success',
   
    text: '<%= orderMessage %>',
  timer: 2000,
    showConfirmButton: false
  });
</script>
<% } %>
<%- include('../../views/partials/user/footer') %>