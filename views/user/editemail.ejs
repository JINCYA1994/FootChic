
<%- include("../../views/partials/user/header") %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Name | FootChic</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

  <style>
    body {
      background-color: #f5f5f5;
    }

    .edit-name-container {
      max-width: 450px;
      margin: 100px auto;
      padding: 40px;
      border: 3px solid #000;
      border-radius: 20px;
      background-color: #fff;
      box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
      text-align: center;
    }

    .edit-name-container h4 {
      font-weight: 700;
      font-size: 22px;
      margin-bottom: 20px;
      color: #000;
    }

    .edit-name-container p {
      font-size: 14px;
      color: #333;
      margin-bottom: 25px;
    }

    .form-label {
      font-weight: 600;
      text-align: left;
      display: block;
      margin-bottom: 8px;
      color: #000;
    }

    .form-control {
      background-color: #ddd;
      border: none;
      border-radius: 5px;
      height: 45px;
      padding-left: 15px;
      font-size: 15px;
      margin-bottom: 20px;
    }

    .btn-save {
      width: 100%;
      height: 45px;
      font-weight: 600;
      background-color: #000;
      color: #fff;
      border-radius: 5px;
      border: none;
      transition: background-color 0.3s ease;
    }

    .btn-save:hover {
      background-color: #333;
    }

    .back-link {
      margin-top: 15px;
      display: block;
      font-size: 14px;
      text-decoration: none;
      color: #007bff;
    }
  </style>
</head>
<body>

  <div class="edit-name-container">
    <h4>Add an email address</h4>

    <p>
     Enter the new email address you would like to associate with your account below. We will send a One Time Password (OTP) to that address.
    </p>


    <form action="/edit-email?_method=PATCH" method="POST">
      <div class="mb-3 text-start">
        <label for="newEmail" class="form-label">New email address</label>
        <input 
          type="text" 
          class="form-control" 
          id="newEmail" 
          name="email" 
          value="<%= userData.email %>" 
          required
        />
      </div>

      <button type="submit" class="btn btn-save">continue</button>
    </form>


  </div>

</body>
</html>

<%- include("../../views/partials/user/footer") %>
