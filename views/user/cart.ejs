<%- include("../../views/partials/user/header") %>

  <!DOCTYPE html>
  <html lang="en">

  <head>
    <meta charset="UTF-8">
    <title>My Cart | FootChic</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">

    <style>
      body {
        background: #f6f2ea;
        font-family: "Segoe UI", sans-serif;
      }

      .cart-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .cart-card {
        width: 1000px;
        background: #fff;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      }

      .cart-card h2 {
        margin-bottom: 30px;
        font-size: 28px;
      }

      table {
        width: 100%;
      }

      th {
        background: #f1ece4;
        padding: 12px;
        font-weight: 600;
      }

      td {
        padding: 15px;
        vertical-align: middle;
      }

      .product-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
      }

      .qty-box {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .qty-btn {
        border: 1px solid #ddd;
        background: #fff;
        padding: 5px 12px;
        border-radius: 8px;
        cursor: pointer;
      }

      .remove-btn {
        border: 1px solid red;
        background: #fff;
        color: red;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 14px;
      }

      .cart-total-box {
        margin-top: 35px;
        background: #f8f4ee;
        padding: 25px;
        border-radius: 15px;
        text-align: center;
      }

      .checkout-btn {
        width: 100%;
        background: #c99a5b;
        border: none;
        padding: 14px;
        border-radius: 30px;
        color: #fff;
        font-size: 16px;
        font-weight: 600;
        margin-top: 15px;
        transition: 0.3s;
      }

      .checkout-btn:hover {
        background: #b88646;
      }
    </style>
  </head>

  <body>
    <div class="cart-wrapper">
      <div class="cart-card">
        <h2>My Cart</h2>

        <% if(cart && cart.items.length> 0) { %>
          <table class="table">
            <thead>
              <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
                <th>Remove</th>
              </tr>
            </thead>
            <tbody>
              <% cart.items.forEach(item=> { %>
                <tr class="<%= item.isUnavailable ? 'table-danger' : '' %>">
                  <td>
                    <img src="<%= item.image %>" class="product-img">
                  </td>
                  <td>
                    <%= item.product_name %>

                      <% if (item.isUnavailable) { %>
                        <div style="color:red; font-size:12px;">
                          Product unavailable
                        </div>
                        <% } %>
                  </td>
                  <td>₹<%= item.price %>
                  </td>
                  <td>
                    <div class="qty-box">
                      <button class="qty-btn"  
<%= item.isUnavailable ? 'disabled' : '' %> 
 data-id="<%= item._id %>" data-action="decrement">-
</button>

                      <span class="qty-value">
                        <%= item.quantity %>
                      </span>

                      <button class="qty-btn"  <%= item.isUnavailable ? 'disabled' : '' %>  data-id="<%= item._id %>" data-action="increment">+</button>
                    </div>
                  </td>
                  <td>₹<%= item.total %>
                  </td>
                  <td>
                    <button class="remove-btn" data-id="<%= item._id %>">Remove</button>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>

          <div class="cart-total-box">
            <h5>Cart Total: ₹<%= cart.total %>
            </h5>
            <!-- <a href="/checkout">
              <button class="checkout-btn">Proceed To Checkout</button>
            </a> -->
            <button
  id="checkoutBtn"
  class="checkout-btn">
  Proceed To Checkout
</button>
          </div>

          <% } else { %>
            <div class="text-center">
              <h4>Your cart is empty 🛒</h4>
              <a href="/shop" class="btn btn-dark mt-3">Continue Shopping</a>
            </div>
            <% } %>

      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
checkoutBtn.addEventListener(

'click',

async()=>{

const response =

await fetch(
'/checkout/check-items'
);

const data =
await response.json();

if(!data.unavailable){

window.location.href=
'/checkout';

return;

}

const result=
await Swal.fire({

icon:'warning',

title:'Some items are unavailable',

text:
'These items will be removed from your cart. Continue?',

showCancelButton:true,

confirmButtonText:'Continue',

cancelButtonText:'Stay Here'

});

if(result.isConfirmed){

window.location.href=

'/checkout?removeUnavailable=true';

}

});

      const removeButtons = document.querySelectorAll('.remove-btn');

      removeButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const itemId = button.getAttribute('data-id');

          const result = await Swal.fire({
            title: 'Are you sure?',
            text: "Do you want to remove this item from cart?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, remove it!'
          });

          if (result.isConfirmed) {
            try {
              const res = await fetch(`/remove-cart/${itemId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
              });
              const data = await res.json();

              if (data.success) {
                button.closest('tr').remove();

                const totalBox = document.querySelector('.cart-total-box h5');
                if (totalBox) totalBox.innerText = `Cart Total: ₹${data.cartTotal}`;


                const cartCount = document.getElementById('cart-count');
                if (cartCount) cartCount.innerText = data.totalItems;

                if (data.cartTotal === 0) {
                  document.querySelector('.cart-wrapper').innerHTML = `
              <div class="text-center">
                <h4>Your cart is empty 🛒</h4>
                <a href="/shop" class="btn btn-dark mt-3">Continue Shopping</a>
              </div>`;
                }

                Swal.fire('Removed!', 'Item has been removed from your cart.', 'success');
              }

            } catch (err) {
              console.error(err);
              Swal.fire('Error!', 'Something went wrong.', 'error');
            }
          }
        });
      });


      const qtyButtons = document.querySelectorAll('.qty-btn');

      qtyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const itemId = button.getAttribute('data-id');
          const action = button.getAttribute('data-action');
          const row = button.closest('tr');

          try {
            const res = await fetch('/cart/update-quantity', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ itemId, action })
            });

            const data = await res.json();

            if (data.success) {

              row.querySelector('.qty-value').innerText = data.quantity;


              const price = parseInt(row.querySelector('td:nth-child(3)').innerText.replace('₹', ''));
              row.querySelector('td:nth-child(5)').innerText = `₹${price * data.quantity}`;


              document.querySelector('.cart-total-box h5').innerText =
                `Cart Total: ₹${data.cartTotal}`;
              const cartCount = document.getElementById('cart-count');
              if (cartCount) {
                cartCount.innerText = data.totalItems;
              }

            } else {
              Swal.fire('Oops!', data.message, 'warning');
            }

          } catch (err) {
            console.error(err);
            Swal.fire('Error!', 'Something went wrong.', 'error');
          }
        });
      });




    </script>

   
    <% if (cartError){ %>
      <script>
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: '<%= cartError %>',
          timer: 2000,
          showConfirmButton: false
        });
      </script>
      <% } %>


  </body>

  </html>

  <%- include("../../views/partials/user/footer") %>